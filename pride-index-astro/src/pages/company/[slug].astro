---
import Layout from '../../layouts/Layout.astro';
import { companies, BAND_COLORS, fmtPts, sectors } from '../../lib/data';
import type { Company } from '../../lib/types';
import {
  BandChip,
  Citation,
  ConfidenceBadge,
  FlagChips,
  GradientBar,
  SectionHeading,
  TrajectoryBadge,
} from '../../components/ui.tsx';
import CompanyMiniHeader from '../../components/CompanyMiniHeader.tsx';
import ScoreTimeline from '../../components/ScoreTimeline.tsx';

export function getStaticPaths() {
  return companies.map((c) => ({ params: { slug: c.slug }, props: { company: c } }));
}

const base = import.meta.env.BASE_URL;
const c = Astro.props.company as Company;

const positives = c.actions.filter((a) => a.polarity === 'Positive');
const negatives = c.actions.filter((a) => a.polarity === 'Negative');
const sectorStats = sectors.find((s) => s.sector === c.sector);
const b = c.breakdown;
const r = c.rationale;

const metaDesc = r
  ? `${c.name} scores ${c.score}/100 (${c.band}) on the Corporate Pride Index. ${r.verdict}`
  : `${c.name} scores ${c.score}/100 (${c.band}) on the Corporate Pride Index — the depth and consistency of its LGBTQ+ support, recomputed from sourced evidence.`;
---

<Layout title={`${c.name} — The Corporate Pride Index`} description={metaDesc} path={`company/${c.slug}`}>
  <CompanyMiniHeader client:load name={c.name} score={c.score} band={c.band} base={base} />

  <div class="wrap">
    <div class="detail">
      <a href={base} class="cite" style="font-family:var(--sans);font-size:13px;color:var(--txt-mut)">← Index</a>

      {/* Hero */}
      <div id="company-hero" class="d-top" style="margin-top:18px">
        <div>
          <div class="d-kick">
            {c.sector}{c.ticker ? ` · ${c.ticker}` : ''}{c.revenueB ? ` · $${c.revenueB}B revenue` : ''}
          </div>
          <div class="d-name">{c.name}</div>
        </div>
        <div>
          <div class="d-score" style={{ color: BAND_COLORS[c.band] }}>{c.score}</div>
          <div class="d-score"><BandChip band={c.band} /></div>
        </div>
      </div>
      {c.flags && <div style="margin-top:14px"><FlagChips flags={c.flags} /></div>}

      <GradientBar score={c.score} showLabels markers={sectorStats ? [{ score: sectorStats.avgScore, label: `${c.sector} average` }] : []} />

      {/* THE WHY */}
      {
        r && (
          <div class="why">
            <div class="verdict">{r.verdict}</div>
            <div class="badges"><TrajectoryBadge trajectory={r.trajectory} /><ConfidenceBadge confidence={r.confidence} /></div>
            <div class="cols">
              <div class="col up"><div class="lab">What raised the score</div><p>{r.driversUp}</p></div>
              <div class="col down"><div class="lab">What lowered it</div><p>{r.driversDown}</p></div>
            </div>
            {r.decisiveFactor && <div class="decisive"><div class="lab">What tipped the score</div><p>{r.decisiveFactor}</p></div>}
          </div>
        )
      }

      {/* Score timeline (island — chart + rationale) */}
      {
        c.timeline.length > 0 && (
          <>
            <div class="d-k" style="margin-top:34px">How the score moved, and why</div>
            <div class="d-h3" style="margin:4px 0 0">Score timeline {c.timeline[0].year} → {c.timeline[c.timeline.length - 1].year}</div>
            <ScoreTimeline client:visible c={c} />
          </>
        )
      }

      {/* Scoring breakdown */}
      <div class="d-k" style="margin-top:34px">The arithmetic</div>
      <div class="d-h3" style="margin:4px 0 0">Full scoring breakdown</div>
      <table class="brk">
        <tbody>
          <tr><td>Baseline</td><td class="v">50</td></tr>
          <tr>
            <td>Cosmetic + Commercial (capped at +20){b.cosmeticCommercialRaw > b.cosmeticCommercialCapped ? ` (raw +${b.cosmeticCommercialRaw})` : ''}</td>
            <td class="v pos">+{b.cosmeticCommercialCapped}</td>
          </tr>
          <tr><td>Civic</td><td class="v pos">+{b.civic}</td></tr>
          <tr><td>Financial</td><td class="v pos">+{b.financial}</td></tr>
          <tr><td>Structural</td><td class="v pos">+{b.structural}</td></tr>
          <tr><td>Negative actions (uncapped)</td><td class="v neg">{b.negative}</td></tr>
          <tr class="tot"><td>Final score (clamped 0–100)</td><td class="v" style={{ color: BAND_COLORS[c.band] }}>{c.score}</td></tr>
        </tbody>
      </table>

      {
        c.actions.length === 0 ? (
          <div class="note">No public pro- or anti-LGBTQ+ actions met the index's sourcing bar for this company.
            It holds the neutral baseline of 50 by absence of evidence, not by virtue.</div>
        ) : (
          <>
            <div class="d-k" style="margin-top:34px">The evidence behind the reasoning</div>
            <div class="d-h3" style="margin:4px 0 0">Sourced actions</div>
            <div class="evgrid">
              <div class="evcol p">
                <div class="lab">Positive · {positives.length} · +{b.positiveCapped} after cap</div>
                {positives.map((a) => (
                  <div class="acard" style="border-left-color:#10b981" id={`action-${a.actionId}-${a.year}`}>
                    <span class="pts" style="color:#10b981">{fmtPts(a.points)}</span>
                    <div class="desc">{a.description}</div>
                    <div class="meta">
                      <span>{a.year}</span><span>{a.tier !== '—' ? a.tier : 'Negative'}</span>
                      {a.postJan2025 && <span style="color:var(--bad)">POST–JAN 2025</span>}
                      <Citation url={a.sourceUrl} type={a.sourceType} />
                    </div>
                    {a.notes && <div class="meta" style="font-style:italic">{a.notes}</div>}
                  </div>
                ))}
                {positives.length === 0 && <div class="note">None on record.</div>}
              </div>
              <div class="evcol n">
                <div class="lab">Negative · {negatives.length} · {b.negative || 0}</div>
                {negatives.map((a) => (
                  <div class="acard" style="border-left-color:#f05252" id={`action-${a.actionId}-${a.year}`}>
                    <span class="pts" style="color:#f05252">{fmtPts(a.points)}</span>
                    <div class="desc">{a.description}</div>
                    <div class="meta">
                      <span>{a.year}</span><span>{a.tier !== '—' ? a.tier : 'Negative'}</span>
                      {a.postJan2025 && <span style="color:var(--bad)">POST–JAN 2025</span>}
                      <Citation url={a.sourceUrl} type={a.sourceType} />
                    </div>
                    {a.notes && <div class="meta" style="font-style:italic">{a.notes}</div>}
                  </div>
                ))}
                {negatives.length === 0 && <div class="note">None on record.</div>}
              </div>
            </div>
          </>
        )
      }

      {/* Statements */}
      {
        c.statements.length > 0 && (
          <>
            <div class="d-k" style="margin-top:34px">In their own words</div>
            <div class="d-h3" style="margin:4px 0 0">Statements &amp; reports</div>
            {c.statements.map((s) => (
              <div class="stmt">
                <div class="q">{s.excerpt}</div>
                <div class="cap">
                  <span>{s.recordType}</span>{s.date && <span>{s.date}</span>}{s.speaker && <span>— {s.speaker}</span>}
                  <Citation url={s.sourceUrl} />
                </div>
              </div>
            ))}
          </>
        )
      }

      {/* Social */}
      {
        c.social.length > 0 && (
          <>
            <div class="d-k" style="margin-top:34px">The public record</div>
            <div class="d-h3" style="margin:4px 0 0">Pride-related social activity</div>
            {c.social.map((p) => (
              <div class="acard" style={p.deleted ? 'border-left-color:#f05252' : 'border-left-color:var(--line)'}>
                <div class="meta" style="margin-top:0">
                  <span style="color:var(--txt)">{p.platform}</span>{p.date && <span>{p.date}</span>}
                  {p.deleted && <span style="color:var(--bad)">✕ LATER DELETED</span>}
                </div>
                <div class="desc" style={p.deleted ? 'text-decoration:line-through' : ''}>{p.description}</div>
                {p.notes && <div class="meta" style="font-style:italic">{p.notes}</div>}
                <div class="meta"><Citation url={p.url} /></div>
              </div>
            ))}
          </>
        )
      }

      {/* HRC CEI */}
      <div class="d-k" style="margin-top:34px">Cross-reference</div>
      <div class="d-h3" style="margin:4px 0 0">HRC Corporate Equality Index</div>
      <div class="note">
        {
          c.hrcCei !== null ? (
            <>
              HRC CEI score: <b style="color:var(--ink)">{c.hrcCei}/100</b>{c.ceiYear ? ` (${c.ceiYear})` : ''}.
              {c.stillSubmittingCei === false && (
                <span style="color:var(--bad)"> ⚑ {c.name} has stopped submitting to the CEI — its last score
                  ({c.hrcCei}, {c.ceiYear}) reads as historical, not current.</span>
              )}
              {c.stillSubmittingCei && <span style="color:var(--txt-mut)"> Still participating in the CEI.</span>}
            </>
          ) : (
            'No HRC CEI score on record for this company.'
          )
        }
      </div>

      {/* Analyst notes */}
      {
        c.analystNotes && (
          <>
            <div class="d-k" style="margin-top:34px">Context</div>
            <div class="d-h3" style="margin:4px 0 0">Analyst notes</div>
            <div class="note">{c.analystNotes}</div>
          </>
        )
      }

      <div style="margin-top:34px;display:flex;gap:20px;flex-wrap:wrap">
        <a class="cite" style="font-family:var(--sans);font-size:14px" href={`${base}compare?c=${c.slug}`}>Compare {c.name} against its peers →</a>
        <a class="cite" style="font-family:var(--sans);font-size:14px;color:var(--txt-mut)" href={`${base}methodology`}>How scoring works</a>
      </div>
    </div>
  </div>
</Layout>
