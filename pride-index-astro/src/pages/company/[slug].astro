---
import Layout from '../../layouts/Layout.astro';
import { companies, BAND_COLORS, fmtPts, sectors } from '../../lib/data';
import type { Company } from '../../lib/types';
import {
  BandChip,
  Citation,
  ConfidenceBadge,
  FlagChips,
  GradientBar,
  SectionHeading,
  TrajectoryBadge,
} from '../../components/ui.tsx';
import CompanyMiniHeader from '../../components/CompanyMiniHeader.tsx';
import ScoreTimeline from '../../components/ScoreTimeline.tsx';

export function getStaticPaths() {
  return companies.map((c) => ({ params: { slug: c.slug }, props: { company: c } }));
}

const base = import.meta.env.BASE_URL;
const c = Astro.props.company as Company;

const positives = c.actions.filter((a) => a.polarity === 'Positive');
const negatives = c.actions.filter((a) => a.polarity === 'Negative');
const sectorStats = sectors.find((s) => s.sector === c.sector);
const b = c.breakdown;
const r = c.rationale;

const metaDesc = r
  ? `${c.name} scores ${c.score}/100 (${c.band}) on the Corporate Pride Index. ${r.verdict}`
  : `${c.name} scores ${c.score}/100 (${c.band}) on the Corporate Pride Index — the depth and consistency of its LGBTQ+ support, recomputed from sourced evidence.`;
---

<Layout title={`${c.name} — The Corporate Pride Index`} description={metaDesc} path={`company/${c.slug}`}>
  <CompanyMiniHeader client:load name={c.name} score={c.score} band={c.band} base={base} />

  <div class="mx-auto max-w-5xl px-4 sm:px-6 py-10 space-y-10">
    <a href={base} class="text-xs text-ink-400 hover:text-white">← Index</a>

    {/* Hero */}
    <section id="company-hero" class="flex flex-col sm:flex-row sm:items-end gap-6 justify-between">
      <div class="min-w-0">
        <p class="label mb-2">
          {c.sector}
          {c.ticker && <span class="ml-2 font-mono normal-case">({c.ticker})</span>}
          {c.revenueB && <span class="ml-2 font-mono normal-case">${c.revenueB}B revenue</span>}
        </p>
        <h1 class="font-display text-5xl text-white leading-none">{c.name}</h1>
        <div class="mt-4">
          <FlagChips flags={c.flags} />
        </div>
      </div>
      <div class="shrink-0 text-right">
        <div class="font-mono text-7xl leading-none" style={{ color: BAND_COLORS[c.band] }}>
          {c.score}
        </div>
        <div class="mt-2 flex justify-end">
          <BandChip band={c.band} size="lg" />
        </div>
      </div>
    </section>

    <GradientBar
      score={c.score}
      showLabels
      markers={sectorStats ? [{ score: sectorStats.avgScore, label: `${c.sector} average` }] : []}
    />

    {/* THE WHY */}
    {
      r && (
        <section id="why" class="scroll-mt-20">
          <div class="card p-6 sm:p-8 border-ink-600">
            <p class="label mb-3">Why this score</p>
            <p class="font-display text-2xl sm:text-[1.7rem] leading-snug text-white">{r.verdict}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              <TrajectoryBadge trajectory={r.trajectory} />
              <ConfidenceBadge confidence={r.confidence} />
            </div>
            <div class="mt-6 grid md:grid-cols-2 gap-4">
              <div class="rounded-lg bg-emerald-500/5 border border-emerald-500/20 p-4">
                <p class="label text-emerald-400 mb-2">What raised the score</p>
                <p class="text-sm leading-relaxed text-ink-200">{r.driversUp}</p>
                <a href="#evidence-positive" class="mt-3 inline-block text-xs text-emerald-400/90 hover:underline">
                  See the {positives.length} sourced positive actions ↓
                </a>
              </div>
              <div class="rounded-lg bg-red-500/5 border border-red-500/20 p-4">
                <p class="label text-red-400 mb-2">What lowered it</p>
                <p class="text-sm leading-relaxed text-ink-200">{r.driversDown}</p>
                <a href="#evidence-negative" class="mt-3 inline-block text-xs text-red-400/90 hover:underline">
                  See the {negatives.length} sourced negative actions ↓
                </a>
              </div>
            </div>
            <div class="mt-4 rounded-lg border border-band-neutral/30 bg-band-neutral/5 p-4">
              <p class="label text-band-neutral mb-1">What tipped the score</p>
              <p class="text-sm leading-relaxed text-ink-100">{r.decisiveFactor}</p>
              <a href="#evidence" class="mt-2 inline-block text-xs text-sky-400 hover:underline">
                Check the evidence trail ↓
              </a>
            </div>
          </div>
        </section>
      )
    }

    {/* Score timeline (island — chart) */}
    {
      c.timeline.length > 0 && (
        <section id="timeline" class="scroll-mt-20">
          <SectionHeading
            kicker="How the score moved, and why"
            title={`Score timeline ${c.timeline[0].year} → ${c.timeline[c.timeline.length - 1].year}`}
          />
          <ScoreTimeline client:visible c={c} />
        </section>
      )
    }

    {/* Scoring breakdown */}
    <section id="evidence" class="scroll-mt-20">
      <SectionHeading kicker="The evidence behind the reasoning" title="Full scoring breakdown" />
      <div class="card p-4 mb-6 overflow-x-auto">
        <table class="font-mono text-sm w-full min-w-[540px]">
          <tbody>
            <tr class="text-ink-300">
              <td class="py-1 pr-4">Baseline</td>
              <td class="text-right text-white">50</td>
              <td class="pl-6 text-xs text-ink-400">every company starts neutral</td>
            </tr>
            <tr class="text-ink-300">
              <td class="py-1 pr-4">Cosmetic + Commercial (capped at +20)</td>
              <td class="text-right text-emerald-400">
                +{b.cosmeticCommercialCapped}
                {b.cosmeticCommercialRaw > b.cosmeticCommercialCapped && (
                  <span class="text-ink-400 text-xs"> (raw +{b.cosmeticCommercialRaw})</span>
                )}
              </td>
              <td class="pl-6 text-xs text-ink-400">rainbow-washing cap applied</td>
            </tr>
            <tr class="text-ink-300">
              <td class="py-1 pr-4">Civic</td>
              <td class="text-right text-emerald-400">+{b.civic}</td>
              <td />
            </tr>
            <tr class="text-ink-300">
              <td class="py-1 pr-4">Financial</td>
              <td class="text-right text-emerald-400">+{b.financial}</td>
              <td />
            </tr>
            <tr class="text-ink-300">
              <td class="py-1 pr-4">Structural</td>
              <td class="text-right text-emerald-400">+{b.structural}</td>
              <td class="pl-6 text-xs text-ink-400">hardest to fake, hardest to reverse</td>
            </tr>
            <tr class="text-ink-300">
              <td class="py-1 pr-4">Negative actions (uncapped)</td>
              <td class="text-right text-red-400">{b.negative}</td>
              <td class="pl-6 text-xs text-ink-400">reversal asymmetry by design</td>
            </tr>
            <tr class="border-t border-ink-700 text-white">
              <td class="py-1.5 pr-4 font-medium">Final score (clamped 0–100)</td>
              <td class="text-right text-lg" style={{ color: BAND_COLORS[c.band] }}>{c.score}</td>
              <td class="pl-6 text-xs text-ink-400">recomputed from the rows below at build time</td>
            </tr>
          </tbody>
        </table>
      </div>

      {
        c.actions.length === 0 ? (
          <p class="text-sm text-ink-300 card p-4">
            No public pro- or anti-LGBTQ+ actions met the index's sourcing bar for this company. It
            holds the neutral baseline of 50 by absence of evidence, not by virtue.
          </p>
        ) : (
          <div class="grid lg:grid-cols-2 gap-6">
            <div id="evidence-positive" class="scroll-mt-20 space-y-2">
              <p class="label text-emerald-400">
                Positive actions · {positives.length} · +{b.positiveCapped} pts after cap
              </p>
              {positives.map((a) => (
                <div class="card p-3 border-l-2" style={{ borderLeftColor: '#10b981' }} id={`action-${a.actionId}-${a.year}`}>
                  <div class="flex items-start justify-between gap-3">
                    <div class="min-w-0">
                      <p class="text-sm text-ink-100 leading-snug">{a.description}</p>
                      <div class="mt-1.5 flex flex-wrap items-center gap-x-3 gap-y-1 text-[11px] text-ink-400">
                        <span class="font-mono">{a.year}</span>
                        <span>{a.tier !== '—' ? a.tier : 'Negative action'}</span>
                        <span class="font-mono text-ink-600">{a.actionId}</span>
                        {a.postJan2025 && (
                          <span class="text-red-400 font-medium uppercase tracking-wide">post–Jan 2025</span>
                        )}
                      </div>
                      {a.notes && <p class="mt-1.5 text-xs text-ink-300 italic">{a.notes}</p>}
                      <div class="mt-1.5">
                        <Citation url={a.sourceUrl} type={a.sourceType} />
                      </div>
                    </div>
                    <span class="font-mono text-lg shrink-0" style={{ color: '#10b981' }}>{fmtPts(a.points)}</span>
                  </div>
                </div>
              ))}
              {positives.length === 0 && <p class="text-sm text-ink-400 card p-3">None on record.</p>}
            </div>
            <div id="evidence-negative" class="scroll-mt-20 space-y-2">
              <p class="label text-red-400">
                Negative actions · {negatives.length} · {b.negative || 0} pts
              </p>
              {negatives.map((a) => (
                <div class="card p-3 border-l-2" style={{ borderLeftColor: '#ef4444' }} id={`action-${a.actionId}-${a.year}`}>
                  <div class="flex items-start justify-between gap-3">
                    <div class="min-w-0">
                      <p class="text-sm text-ink-100 leading-snug">{a.description}</p>
                      <div class="mt-1.5 flex flex-wrap items-center gap-x-3 gap-y-1 text-[11px] text-ink-400">
                        <span class="font-mono">{a.year}</span>
                        <span>{a.tier !== '—' ? a.tier : 'Negative action'}</span>
                        <span class="font-mono text-ink-600">{a.actionId}</span>
                        {a.postJan2025 && (
                          <span class="text-red-400 font-medium uppercase tracking-wide">post–Jan 2025</span>
                        )}
                      </div>
                      {a.notes && <p class="mt-1.5 text-xs text-ink-300 italic">{a.notes}</p>}
                      <div class="mt-1.5">
                        <Citation url={a.sourceUrl} type={a.sourceType} />
                      </div>
                    </div>
                    <span class="font-mono text-lg shrink-0" style={{ color: '#ef4444' }}>{fmtPts(a.points)}</span>
                  </div>
                </div>
              ))}
              {negatives.length === 0 && <p class="text-sm text-ink-400 card p-3">None on record.</p>}
            </div>
          </div>
        )
      }
    </section>

    {/* Statements */}
    {
      c.statements.length > 0 && (
        <section id="statements" class="scroll-mt-20">
          <SectionHeading kicker="In their own words" title="Statements & reports" />
          <div class="space-y-3">
            {c.statements.map((s) => (
              <figure class="card p-4">
                <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-[11px] text-ink-400 mb-2">
                  <span class="uppercase tracking-wider font-medium text-ink-300">{s.recordType}</span>
                  {s.date && <span class="font-mono">{s.date}</span>}
                  <span>{s.title}</span>
                </div>
                <blockquote class="border-l-2 border-ink-600 pl-4 text-[15px] leading-relaxed text-ink-100 font-display">
                  {s.excerpt}
                </blockquote>
                <figcaption class="mt-2 flex flex-wrap items-center gap-3 text-xs text-ink-400">
                  {s.speaker && <span>— {s.speaker}</span>}
                  <Citation url={s.sourceUrl} />
                </figcaption>
              </figure>
            ))}
          </div>
        </section>
      )
    }

    {/* Social feed */}
    {
      c.social.length > 0 && (
        <section id="social" class="scroll-mt-20">
          <SectionHeading kicker="The public record" title="Pride-related social activity" />
          <div class="space-y-2">
            {c.social.map((p) => (
              <div class={`card p-3 flex items-start justify-between gap-3 ${p.deleted ? 'opacity-80 border-red-900/60' : ''}`}>
                <div class="min-w-0">
                  <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-[11px] text-ink-400">
                    <span class="text-ink-200 font-medium">{p.platform}</span>
                    {p.date && <span class="font-mono">{p.date}</span>}
                    {p.deleted && (
                      <span class="text-red-400 font-medium uppercase tracking-wide">✕ later deleted</span>
                    )}
                  </div>
                  <p class={`mt-1 text-sm text-ink-100 ${p.deleted ? 'line-through decoration-red-500/60 decoration-1' : ''}`}>
                    {p.description}
                  </p>
                  {p.notes && <p class="mt-1 text-xs text-ink-300 italic">{p.notes}</p>}
                  <div class="mt-1.5">
                    <Citation url={p.url} />
                  </div>
                </div>
              </div>
            ))}
          </div>
        </section>
      )
    }

    {/* HRC CEI cross-reference */}
    <section>
      <SectionHeading kicker="Cross-reference" title="HRC Corporate Equality Index" />
      <div class="card p-4 text-sm text-ink-200 leading-relaxed">
        {
          c.hrcCei !== null ? (
            <>
              <p>
                HRC CEI score: <span class="font-mono text-white text-base">{c.hrcCei}/100</span>
                {c.ceiYear && <span class="text-ink-400 font-mono"> ({c.ceiYear})</span>}.
              </p>
              {c.stillSubmittingCei === false && (
                <p class="mt-2 rounded border border-red-500/40 bg-red-500/10 text-red-300 px-3 py-2">
                  ⚑ {c.name} has <strong>stopped submitting</strong> to the HRC Corporate Equality
                  Index — its last score ({c.hrcCei}, {c.ceiYear}) no longer reflects current policy
                  and should be read as historical, not current.
                </p>
              )}
              {c.stillSubmittingCei && <p class="mt-1 text-ink-400 text-xs">Still participating in the CEI.</p>}
            </>
          ) : (
            <p>No HRC CEI score on record for this company.</p>
          )
        }
      </div>
    </section>

    {/* Analyst notes */}
    {
      c.analystNotes && (
        <section>
          <SectionHeading kicker="Context" title="Analyst notes" />
          <p class="card p-4 text-sm leading-relaxed text-ink-200">{c.analystNotes}</p>
        </section>
      )
    }

    <div class="pt-2 flex gap-4">
      <a href={`${base}compare?c=${c.slug}`} class="text-sm text-sky-400 hover:underline">
        Compare {c.name} against its peers →
      </a>
      <a href={`${base}methodology`} class="text-sm text-ink-400 hover:text-white">How scoring works</a>
    </div>
  </div>
</Layout>
