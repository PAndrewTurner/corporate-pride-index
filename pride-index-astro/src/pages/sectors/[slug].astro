---
import Layout from '../../layouts/Layout.astro';
import {
  BAND_COLORS,
  companiesInSector,
  fmtPts,
  median,
  sectors,
  sectorTimeline,
  slugifySector,
} from '../../lib/data';
import { bandFor } from '../../lib/scoring';
import { BandChip, FlagChips, SectionHeading } from '../../components/ui.tsx';
import SectorTimelineChart from '../../components/SectorTimelineChart.tsx';

export function getStaticPaths() {
  return sectors.map((s) => ({
    params: { slug: slugifySector(s.sector) },
    props: { stat: s },
  }));
}

const base = import.meta.env.BASE_URL;
const stat = Astro.props.stat;

const cs = companiesInSector(stat.sector);
const series = sectorTimeline(stat.sector);
const med = median(cs.map((c) => c.score));
const first = series[0];
const last = series[series.length - 1];
const change = last && first ? Math.round((last.median - first.median) * 10) / 10 : 0;
const changeColor = change < 0 ? 'text-red-400' : change > 0 ? 'text-emerald-400' : 'text-ink-300';
---

<Layout
  title={`${stat.sector} — The Corporate Pride Index`}
  description={`How the ${stat.sector} sector has moved on LGBTQ+ support: median ${med}, average ${stat.avgScore}, across ${stat.companies} companies tracked from 2015 to now.`}
  path={`sectors/${slugifySector(stat.sector)}`}
>
  <div class="wrap">
    <div class="detail">
      <a href={`${base}sectors`} class="cite" style="font-family:var(--sans);font-size:13px;color:var(--txt-mut)">← All sectors</a>

      <div class="d-top" style="margin-top:18px">
        <div>
          <div class="d-kick">{stat.companies} {stat.companies === 1 ? 'company' : 'companies'} in the index</div>
          <div class="d-name">{stat.sector}</div>
        </div>
        <div style="display:flex;align-items:flex-end;gap:24px">
          <div style="text-align:right">
            <div style={{ fontFamily: 'var(--serif)', fontSize: '58px', lineHeight: 1, color: BAND_COLORS[bandFor(med)] }}>{med}</div>
            <div class="d-k" style="margin-top:4px">median</div>
          </div>
          <div style="text-align:right">
            <div style={{ fontFamily: 'var(--serif)', fontSize: '34px', lineHeight: 1, color: 'var(--txt-2)' }}>{stat.avgScore}</div>
            <div class="d-k" style="margin-top:4px">average</div>
          </div>
        </div>
      </div>

      {
        series.length > 0 && (
          <>
            <div class="d-k" style="margin-top:34px">The sector over time</div>
            <div class="d-h3" style="margin:4px 0 10px">Score {first.year} → {last.year}</div>
            <div style="display:flex;flex-wrap:wrap;gap:6px 16px;font-size:13.5px;color:var(--txt-2);margin-bottom:6px">
              <span>median {first.year} <span style="font-family:var(--mono);color:var(--ink)">{first.median}</span> → {last.year} <span style={{ fontFamily: 'var(--mono)', color: BAND_COLORS[bandFor(last.median)] }}>{last.median}</span></span>
              <span style={{ fontFamily: 'var(--mono)', color: change < 0 ? 'var(--bad)' : change > 0 ? 'var(--good)' : 'var(--txt-mut)' }}>{change === 0 ? '±0' : fmtPts(change)}</span>
              <span style="color:var(--txt-mut)">best <span style="font-family:var(--mono)">{stat.max}</span> · worst <span style="font-family:var(--mono)">{stat.min}</span>{stat.harmfulPlus > 0 ? ` · ${stat.harmfulPlus} harmful or worse` : ''}</span>
            </div>
            <SectorTimelineChart client:visible data={series} />
          </>
        )
      }

      <div class="d-k" style="margin-top:34px">Everyone in this sector</div>
      <div class="d-h3" style="margin:4px 0 14px">{cs.length} {cs.length === 1 ? 'company' : 'companies'}</div>
      <div>
        {
          cs.map((c) => (
            <a class="acard" href={`${base}company/${c.slug}`} style="display:flex;align-items:center;gap:16px;text-decoration:none;border-left-color:var(--line)">
              <div style={{ fontFamily: 'var(--mono)', fontSize: '24px', width: '46px', textAlign: 'right', flexShrink: 0, color: BAND_COLORS[c.band] }}>{c.score}</div>
              <div style="min-width:0;flex:1">
                <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
                  <span style="color:var(--ink);font-weight:500">{c.name}</span>
                  {c.ticker && <span class="tkr">{c.ticker}</span>}
                  <BandChip band={c.band} />
                </div>
                {c.timelineChange !== null && c.timelineChange !== 0 && (
                  <div style="font-size:11.5px;color:var(--txt-mut);margin-top:3px">
                    <span style={{ fontFamily: 'var(--mono)', color: c.timelineChange < 0 ? 'var(--bad)' : 'var(--good)' }}>{fmtPts(c.timelineChange)}</span>
                    {' '}since {c.timeline[0]?.year}{c.trajectoryShape ? ` · ${c.trajectoryShape.toLowerCase()}` : ''}
                  </div>
                )}
              </div>
              <div style="flex-shrink:0"><FlagChips flags={c.flags} size="sm" /></div>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</Layout>
