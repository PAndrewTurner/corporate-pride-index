---
import Layout from '../layouts/Layout.astro';
import { BAND_COLORS, companiesInSector, median, sectors, slugifySector } from '../lib/data';
import { bandFor } from '../lib/scoring';
import { BandChip, SectionHeading } from '../components/ui.tsx';

const base = import.meta.env.BASE_URL;

const rows = sectors
  .map((s) => {
    const cs = companiesInSector(s.sector);
    return { ...s, med: median(cs.map((c) => c.score)) };
  })
  .sort((a, b) => b.med - a.med);
---

<Layout
  title="Sectors — The Corporate Pride Index"
  description="How each industry has moved over the past decade — median and average LGBTQ+ support scores from 2015 to now, by sector."
  path="sectors"
>
  <div class="wrap">
    <div class="page">
      <span class="kick">The index, grouped</span>
      <h1>Sectors</h1>
      <p class="intro">How each industry has moved over the past decade. Pick a sector to see its median
        and average score from 2015 to now, then every company in the index that belongs to it. The
        median is the typical company — it won&apos;t be skewed by a single champion or a single adversary
        in the same industry.</p>
    </div>

    <section class="section">
      <div class="prose"><div class="d-k">Ranked by median score</div><h2>All sectors</h2></div>
      <div class="froadmap" style="margin-top:18px">
        {
          rows.map((s) => (
            <a class="fitem secrow" href={`${base}sectors/${slugifySector(s.sector)}`}>
              <div style="min-width:0">
                <div style="color:var(--ink);font-weight:600;font-size:15px">{s.sector}</div>
                <div style="color:var(--txt-mut);font-size:12.5px;margin-top:4px">
                  {s.companies} {s.companies === 1 ? 'company' : 'companies'} · avg <span style="font-family:var(--mono)">{s.avgScore}</span>
                  {s.champions > 0 && <span> · {s.champions} champion{s.champions > 1 ? 's' : ''}</span>}
                </div>
              </div>
              <div style="display:flex;align-items:center;gap:12px;flex-shrink:0">
                <div style="text-align:right">
                  <div style={{ fontFamily: 'var(--serif)', fontSize: '26px', lineHeight: 1, color: BAND_COLORS[bandFor(s.med)] }}>{s.med}</div>
                  <div class="d-k" style="font-size:9px;margin-top:3px">median</div>
                </div>
                <BandChip band={bandFor(s.med)} />
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</Layout>
