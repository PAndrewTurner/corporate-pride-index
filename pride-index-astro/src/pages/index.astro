---
import Layout from '../layouts/Layout.astro';
import { companies, sectors, fmtPts, BAND_COLORS } from '../lib/data';
import { bandFor } from '../lib/scoring';
import CompanySearch from '../components/CompanySearch.tsx';
import DashboardStats from '../components/DashboardStats.tsx';
import DashboardTable from '../components/DashboardTable.tsx';

const base = import.meta.env.BASE_URL;
const total = companies.length;
const avg = +(companies.reduce((s, c) => s + c.score, 0) / total).toFixed(1);

// Distribution histogram bins (0–9 … 90–100)
const bins = Array.from({ length: 10 }, (_, i) =>
  companies.filter((c) => c.score >= i * 10 && c.score <= (i === 9 ? 100 : i * 10 + 9)).length,
);
const maxBin = Math.max(...bins);

const honor = [...companies]
  .sort((a, b) => b.score - a.score || b.breakdown.structural - a.breakdown.structural)
  .slice(0, 6);
const shame = companies
  .filter((c) => c.flags.postJan2025Reversal)
  .sort((a, b) => a.breakdown.negative - b.breakdown.negative)
  .slice(0, 6);
const sectorsSorted = [...sectors].sort((a, b) => b.avgScore - a.avgScore);
---

<Layout>
  <div class="wrap in">
    <!-- HERO -->
    <section class="hero">
      <div>
        <span class="kicker">A data-journalism accountability instrument</span>
        <h1 class="hero-title">
          <span class="line"><span style="--ld:.15s">Who stood by</span></span>
          <span class="line"><span style="--ld:.27s">LGBTQ+ people —</span></span>
          <span class="line"><span style="--ld:.39s"><em>and who folded</em></span></span>
          <span class="line"><span style="--ld:.51s"><em>under pressure?</em></span></span>
        </h1>
        <p class="lede reveal" style="--d:.7s">
          The Corporate Pride Index scores {total} major American companies from 0 to 100 on the depth
          and consistency of their LGBTQ+ support. Cosmetic gestures are capped; structure is rewarded;
          reversals — especially the post–January 2025 retreats — are the most damning signal.
          <a href={`${base}methodology`}>Read the methodology.</a>
        </p>
        <div class="reveal" style="--d:.82s">
          <CompanySearch client:load base={base} />
        </div>
      </div>
      <aside class="pulse reveal" style="--d:.55s">
        <div class="lab">The index, today</div>
        <div class="big">{avg}</div>
        <div class="sub">mean score across <b>{total}</b> companies · 2015 → 2026</div>
        <div class="gauge">
          <div class="track"><span class="needle" style={`left:${avg}%`}></span></div>
          <div class="ends"><span>0 · Adversarial</span><span>50 · Neutral</span><span>100 · Champion</span></div>
        </div>
      </aside>
    </section>

    <!-- STATS (island) -->
    <DashboardStats client:load />

    <!-- DISTRIBUTION (static) -->
    <section class="block">
      <div class="head"><div><div class="k">The shape of corporate America</div><h2>Score distribution</h2></div><div class="meta">all {total} companies</div></div>
      <div class="dist">
        <div class="bars">
          {
            bins.map((n, i) => {
              const col = BAND_COLORS[bandFor(i * 10 + 5)];
              return (
                <div class="barcol">
                  <div class="bar" style={`height:${Math.round((n / maxBin) * 100)}%;--bd:${0.05 * i}s;background:${col}`}><b>{n}</b></div>
                </div>
              );
            })
          }
        </div>
        <div class="scaleline"></div>
        <div class="scalelabs"><span>0</span><span>Adversarial → Harmful → Performative → Neutral → Ally → Champion</span><span>100</span></div>
      </div>
    </section>

    <!-- HONOR & SHAME (static) -->
    <section class="block">
      <div class="head"><div><div class="k">The extremes</div><h2>Hall of Honor &amp; Hall of Shame</h2></div></div>
      <div class="halls">
        <div class="hall honor">
          <div class="htag">◆ Hall of Honor · highest sustained scores</div>
          <div class="desc">Top scores, weighted toward structural commitments that are hardest to fake — and hardest to reverse.</div>
          {
            honor.map((c, i) => (
              <a class="row" href={`${base}company/${c.slug}`}>
                <span class="rank">{i + 1}</span>
                <span class="nm">{c.name}<small>{c.sector}</small></span>
                <span class="chip" style={{ color: BAND_COLORS[c.band] }}>{c.score}</span>
              </a>
            ))
          }
        </div>
        <div class="hall shame">
          <div class="htag">⚑ Hall of Shame · steepest reversals</div>
          <div class="desc">Post–Jan 2025 reversal companies, ranked by the negative-point damage their retreat inflicted.</div>
          {
            shame.map((c, i) => (
              <a class="row" href={`${base}company/${c.slug}`}>
                <span class="rank">{i + 1}</span>
                <span class="nm">{c.name}<small>{c.sector}</small></span>
                <span class="chip neg">{fmtPts(c.breakdown.negative)}</span>
                <span class="chip" style={{ color: BAND_COLORS[c.band] }}>{c.score}</span>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <!-- SECTORS (static) -->
    <section class="block">
      <div class="head"><div><div class="k">The index, grouped</div><h2>Where sectors stand</h2></div><div class="meta"><a href={`${base}sectors`} style="color:var(--link);text-decoration:none">all sectors →</a></div></div>
      <div class="sect">
        {
          sectorsSorted.map((s, i) => {
            const col = BAND_COLORS[bandFor(s.avgScore)];
            return (
              <a class="srow" href={`${base}sectors/${s.sector.toLowerCase().replace(/&/g,'and').replace(/[^a-z0-9]+/g,'-').replace(/^-+|-+$/g,'')}`} style="text-decoration:none;color:inherit">
                <span class="sn">{s.sector}</span>
                <span class="strack"><span class="sfill" style={`width:${s.avgScore}%;--sd:${0.05 * i}s;background:${col};box-shadow:0 0 16px -4px ${col}`}></span></span>
                <span class="sv">{s.avgScore}</span>
              </a>
            );
          })
        }
      </div>
    </section>

    <!-- FULL TABLE (island) -->
    <section class="block">
      <div class="head"><div><div class="k">Every company, sourced</div><h2>The full index</h2></div></div>
      <DashboardTable client:load base={base} />
    </section>
  </div>
</Layout>
