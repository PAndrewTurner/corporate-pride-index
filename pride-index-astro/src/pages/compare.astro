---
import Layout from '../layouts/Layout.astro';
import CompareApp from '../components/CompareApp.tsx';

const base = import.meta.env.BASE_URL;
---

<Layout
  title="Compare companies — The Corporate Pride Index"
  description="Put 2–4 companies side by side: scores, tier-by-tier point composition, and each company's position against its own sector benchmark."
  path="compare"
>
  <div class="wrap">
    <div class="page">
      <span class="kick">Side by side</span>
      <h1>Compare</h1>
      <p class="intro">Put 2–4 companies next to each other — scores, tier-by-tier point composition, and
        each company's position against its own sector benchmark.</p>
    </div>
    <div class="section">
      <CompareApp client:load base={base} />
    </div>
  </div>
</Layout>
