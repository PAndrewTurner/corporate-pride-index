---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.tsx';
import { data } from '../lib/data';

interface Props {
  title?: string;
  description?: string;
  /** Canonical/OG path relative to the site root, e.g. "company/apple". */
  path?: string;
}

const base = import.meta.env.BASE_URL; // e.g. "/" or "/corporate-pride-index/"
const {
  title = 'The Corporate Pride Index — Accountability, Not Applause',
  description = 'Scoring 200 major American companies on the depth and consistency of their LGBTQ+ support. Every score is one click from its evidence.',
  path = '',
} = Astro.props;

const siteRoot = 'https://pandrewturner.github.io';
const canonical = `${siteRoot}${base}${path}`;
const ogImage = `${siteRoot}${base}social-logo.png`;

// Active-nav detection: normalise the current path against the base prefix.
const here = Astro.url.pathname.replace(base, '/').replace(/\/+$/, '') || '/';
const navItems = [
  { href: base, label: 'Index', match: '/' },
  { href: `${base}sectors`, label: 'Sectors', match: '/sectors' },
  { href: `${base}compare`, label: 'Compare', match: '/compare' },
  { href: `${base}methodology`, label: 'Methodology', match: '/methodology' },
  { href: `${base}future`, label: 'Future Enhancements', match: '/future' },
  { href: `${base}about`, label: 'About', match: '/about' },
];
const isActive = (m: string) => (m === '/' ? here === '/' : here === m || here.startsWith(m + '/'));
const navClass = (active: boolean) =>
  `px-3 py-1.5 rounded text-sm transition-colors ${
    active ? 'bg-ink-800 text-white' : 'text-ink-300 hover:text-white'
  }`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={`${base}favicon.png`} />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph (Facebook, LinkedIn, Slack, iMessage…) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="The Corporate Pride Index" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="The Corporate Pride Index — accountability, not applause" />

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Google Analytics (GA4) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-PJWLCRL2C6"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-PJWLCRL2C6');
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=IBM+Plex+Mono:wght@400;500;600&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Apply stored theme before first paint to avoid a flash of dark mode. -->
    <script is:inline>
      if (localStorage.getItem('cpi-theme') === 'light')
        document.documentElement.classList.add('light');
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="sticky top-0 z-40 border-b border-ink-700/60 bg-ink-950/90 backdrop-blur">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 py-2 flex flex-wrap items-center gap-x-6 gap-y-1.5">
        <div class="min-w-0">
          <a href={base} class="flex items-center gap-2.5">
            <img
              src={`${base}cpi-mark.png`}
              alt=""
              aria-hidden="true"
              class="h-8 sm:h-9 w-auto shrink-0"
            />
            <span class="font-display text-xl sm:text-2xl text-white tracking-wide whitespace-nowrap">
              The Corporate Pride Index
            </span>
            <span class="hidden lg:inline text-[11px] uppercase tracking-[0.18em] text-ink-400 whitespace-nowrap">
              Accountability, not applause
            </span>
          </a>
          <a
            href="https://www.anthropic.com/claude"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-1 flex items-center gap-1.5 text-xs text-ink-300 hover:text-white transition-colors w-fit whitespace-nowrap"
          >
            <svg
              viewBox="0 0 24 24"
              class="w-3.5 h-3.5 shrink-0 text-[#d97757]"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M12 1.5c.6 4.9 1.4 7.2 3.4 9.1 2 1.9 4.3 2.7 7.1 3.4-2.8.7-5.1 1.5-7.1 3.4-2 1.9-2.8 4.2-3.4 9.1-.6-4.9-1.4-7.2-3.4-9.1-2-1.9-4.3-2.7-7.1-3.4 2.8-.7 5.1-1.5 7.1-3.4 2-1.9 2.8-4.2 3.4-9.1Z" />
            </svg>
            Built with Claude Fable 5, Anthropic's latest model
          </a>
        </div>
        <nav class="flex items-center gap-1 ml-auto">
          {
            navItems.map((item) => (
              <a href={item.href} class={navClass(isActive(item.match))}>
                {item.label}
              </a>
            ))
          }
          <ThemeToggle client:load />
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-ink-700/60 mt-16">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 py-8 text-xs text-ink-400 space-y-4">
        <div class="flex flex-wrap gap-x-8 gap-y-2 justify-between">
          <p>
            {data.companies.length} companies · {data.validation.actionsChecked} sourced actions · every
            score independently recomputed from its evidence at build time
            {data.validation.passed ? ' — validation passed.' : ' — VALIDATION FAILED.'}
          </p>
          <p>
            Data generated {new Date(data.generatedAt).toISOString().slice(0, 10)} from{' '}
            <span class="font-mono">{data.workbook}</span>
          </p>
        </div>
        <div class="flex items-center gap-2 pt-3 border-t border-ink-800">
          <svg
            viewBox="0 0 24 24"
            class="w-3.5 h-3.5 shrink-0 text-[#d97757]"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M12 1.5c.6 4.9 1.4 7.2 3.4 9.1 2 1.9 4.3 2.7 7.1 3.4-2.8.7-5.1 1.5-7.1 3.4-2 1.9-2.8 4.2-3.4 9.1-.6-4.9-1.4-7.2-3.4-9.1-2-1.9-4.3-2.7-7.1-3.4 2.8-.7 5.1-1.5 7.1-3.4 2-1.9 2.8-4.2 3.4-9.1Z" />
          </svg>
          <p>
            Built with the assistance of{' '}
            <a
              href="https://www.anthropic.com/claude"
              target="_blank"
              rel="noopener noreferrer"
              class="text-ink-300 hover:text-white underline decoration-ink-600 underline-offset-2"
            >
              Claude Fable 5
            </a>, Anthropic's latest model — data ingestion, scoring validation, and site design.
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
