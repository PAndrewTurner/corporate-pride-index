---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.tsx';
import { data } from '../lib/data';

interface Props {
  title?: string;
  description?: string;
  /** Canonical/OG path relative to the site root, e.g. "company/apple". */
  path?: string;
}

const base = import.meta.env.BASE_URL; // e.g. "/" or "/corporate-pride-index/"
const {
  title = 'The Corporate Pride Index — Accountability, Not Applause',
  description = 'Scoring 200 major American companies on the depth and consistency of their LGBTQ+ support. Every score is one click from its evidence.',
  path = '',
} = Astro.props;

const siteRoot = 'https://pandrewturner.github.io';
const canonical = `${siteRoot}${base}${path}`;
const ogImage = `${siteRoot}${base}social-logo.png`;

// Active-nav detection: normalise the current path against the base prefix.
const here = Astro.url.pathname.replace(base, '/').replace(/\/+$/, '') || '/';
const navItems = [
  { href: base, label: 'Index', match: '/' },
  { href: `${base}sectors`, label: 'Sectors', match: '/sectors' },
  { href: `${base}compare`, label: 'Compare', match: '/compare' },
  { href: `${base}methodology`, label: 'Methodology', match: '/methodology' },
  { href: `${base}future`, label: 'Future', match: '/future' },
  { href: `${base}about`, label: 'About', match: '/about' },
];
const isActive = (m: string) => (m === '/' ? here === '/' : here === m || here.startsWith(m + '/'));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={`${base}favicon.png`} />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph (Facebook, LinkedIn, Slack, iMessage…) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="The Corporate Pride Index" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="The Corporate Pride Index — accountability, not applause" />

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Google Analytics (GA4) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-PJWLCRL2C6"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-PJWLCRL2C6');
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..700&family=Hanken+Grotesk:wght@300..800&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <!-- Apply stored theme before first paint to avoid a flash. -->
    <script is:inline>
      if (localStorage.getItem('cpi-theme') === 'light')
        document.documentElement.classList.add('light');
    </script>
  </head>
  <body>
    <div class="atmos"></div>
    <div class="grain"></div>
    <div class="vignette"></div>

    <header>
      <div class="wrap bar">
        <div class="brand-col">
          <a class="brand-link" href={base}>
            <img src={`${base}cpi-mark.png`} alt="The Corporate Pride Index" />
            <span class="brand"><b>Corporate Pride Index</b><span class="tag">Accountability, Not Applause</span></span>
          </a>
          <a class="hcredit" href="https://www.anthropic.com/claude" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 1.5c.6 4.9 1.4 7.2 3.4 9.1 2 1.9 4.3 2.7 7.1 3.4-2.8.7-5.1 1.5-7.1 3.4-2 1.9-2.8 4.2-3.4 9.1-.6-4.9-1.4-7.2-3.4-9.1-2-1.9-4.3-2.7-7.1-3.4 2.8-.7 5.1-1.5 7.1-3.4 2-1.9 2.8-4.2 3.4-9.1Z"/></svg>
            Built with Claude Fable 5, Anthropic's latest model
          </a>
        </div>
        <nav>
          {navItems.map((item) => <a href={item.href} class={isActive(item.match) ? 'active' : ''}>{item.label}</a>)}
          <ThemeToggle client:load />
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="wrap f">
        <span>
          {data.companies.length} companies · {data.validation.actionsChecked} sourced actions · every score recomputed
          from its evidence at build time{data.validation.passed ? ' — ' : ' — VALIDATION FAILED. '}
          {data.validation.passed && <span class="ok">validation passed.</span>}
        </span>
        <span class="credit">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 1.5c.6 4.9 1.4 7.2 3.4 9.1 2 1.9 4.3 2.7 7.1 3.4-2.8.7-5.1 1.5-7.1 3.4-2 1.9-2.8 4.2-3.4 9.1-.6-4.9-1.4-7.2-3.4-9.1-2-1.9-4.3-2.7-7.1-3.4 2.8-.7 5.1-1.5 7.1-3.4 2-1.9 2.8-4.2 3.4-9.1Z"/></svg>
          Built with <a href="https://www.anthropic.com/claude" target="_blank" rel="noopener">Claude Fable 5</a>, Anthropic's latest model
        </span>
      </div>
    </footer>
  </body>
</html>
